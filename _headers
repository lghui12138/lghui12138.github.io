/*
  Content-Security-Policy upgrade — CSP now covers all page types
*/
## Security headers (applied to all responses)
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  X-XSS-Protection: 0
  Referrer-Policy: no-referrer
  Permissions-Policy: accelerometer=(), autoplay=(), camera=(), display-capture=(), geolocation=(), gyroscope=(), microphone=(), payment=(), usb=(), xr-spatial-tracking=()
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  Cross-Origin-Embedder-Policy: require-corp
  Origin-Agent-Cluster: ?1
  X-Robots-Tag: noindex, nofollow, noarchive, nosnippet
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://unpkg.com https://vjs.zencdn.net; worker-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com https://fonts.googleapis.com; connect-src 'self' https://api.lghui.online https://lghui-fluid-learning.pages.dev https://cdn.jsdelivr.net https://unpkg.com; img-src 'self' data: blob: https://lghui.top https://lghui-fluid-learning.pages.dev; media-src 'self' blob:; frame-ancestors 'none'; base-uri 'none'; form-action 'none'; object-src 'none'

*.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

*.{js,css}
  Cache-Control: public, max-age=31536000, immutable

*.json
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

*.{png,jpg,jpeg,gif,svg,ico,webp}
  Cache-Control: public, max-age=31536000, immutable

*.{woff,woff2,ttf,eot}
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: font/woff2

*.mp4
  Cache-Control: public, max-age=31536000, immutable

*.pdf
  Cache-Control: public, max-age=31536000, immutable