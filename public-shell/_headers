/*
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' https://lghui-fluid-learning.pages.dev; object-src 'none'; base-uri 'self'; form-action 'self' https://lghui-fluid-learning.pages.dev; upgrade-insecure-requests
  X-Robots-Tag: noindex, nofollow, noarchive
  X-Content-Type-Options: nosniff

/sw.js
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Clear-Site-Data: "cache"

/assets/*
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  X-Content-Type-Options: nosniff
